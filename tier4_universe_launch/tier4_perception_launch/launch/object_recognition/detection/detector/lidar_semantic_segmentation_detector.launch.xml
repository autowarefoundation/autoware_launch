<?xml version="1.0"?>
<launch>
  <!-- Current namespace -->
  <arg name="ns" description="current namespace"/>

  <arg name="voxel_grid_based_euclidean_param_path"/>

  <arg name="node/pointcloud_container"/>
  <arg name="euclidean_cluster/input/pointcloud"/>
  <arg name="detected_object_feature_remover/output/objects"/>
  <arg name="euclidean_clustering/shape_policy"/>
  <arg name="euclidean_clustering/param_path"/>

  <!-- Clustering -->
  <group>
    <push-ros-namespace namespace="clustering"/>
    <group>
      <include file="$(find-pkg-share autoware_euclidean_cluster)/launch/label_based_euclidean_cluster.launch.xml">
        <arg name="input_pointcloud" value="/perception/segmented/pointcloud"/>
        <arg name="output_objects" value="/perception/object_recognition/detection/clustering/camera_lidar_fusion/objects"/>
        <arg name="use_low_height_cropbox" value="$(var use_low_height_cropbox)"/>
        <arg name="use_pointcloud_container" value="false"/>
        <arg name="voxel_grid_based_euclidean_param_path" value="$(var voxel_grid_based_euclidean_param_path)"/>
        <arg name="shape_policy" value="$(var euclidean_clustering/shape_policy)"/>
        <arg name="param_path" value="$(var euclidean_clustering/param_path)"/>
      </include>
    </group>

    <!-- shape_estimation 1 -->
