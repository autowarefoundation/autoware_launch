<launch>
  <!-- Params -->
  <arg name="vehicle_mirror_param_file"/>
  <arg name="use_distortion_corrector" default="true"/>
  <arg name="container_name" default="velodyne_node_container"/>
  <arg name="use_polar_voxel_noise_filter" default="false"/>
  <arg name="polar_voxel_noise_filter_node_param_path" default="$(find-pkg-share common_awsim_labs_sensor_launch)/config/polar_voxel_noise_filter_node.param.yaml"/>

  <include file="$(find-pkg-share common_awsim_labs_sensor_launch)/launch/velodyne_node_container.launch.py">
    <arg name="vehicle_mirror_param_file" value="$(var vehicle_mirror_param_file)"/>
    <arg name="use_intra_process" value="true"/>
    <arg name="use_multithread" value="false"/>
    <arg name="use_distortion_corrector" value="$(var use_distortion_corrector)"/>
    <arg name="container_name" value="pointcloud_container"/>
    <arg name="use_polar_voxel_noise_filter" value="$(var use_polar_voxel_noise_filter)"/>
    <arg name="polar_voxel_noise_filter_node_param_path" value="$(var polar_voxel_noise_filter_node_param_path)"/>
  </include>
</launch>
