<launch>
  <arg name="launch_driver" default="true" description="do launch driver"/>
  <arg name="use_sim_time" default="false"/>
  <arg name="vehicle_mirror_param_file" default="$(find-pkg-share autoware_vehicle_info_utils)/config/vehicle_mirror.param.yaml" description="path to the file of vehicle mirror position yaml"/>
  <arg name="vehicle_info_param_file" default="$(find-pkg-share palta_sensor_kit_launch)/config/vehicle_info.param.yaml" description="path to the file of vehicle info yaml"/>
  <arg name="pointcloud_container_name" default="pointcloud_container"/>
  <arg name="lidar1_sensor_ip" default="192.168.1.201" description="LiDAR 1 Hesai sensor IP address"/>
  <arg name="lidar2_sensor_ip" default="192.168.2.201" description="LiDAR 2 Hesai sensor IP address"/>
  <arg name="lidar1_host_ip" default="192.168.1.100" description="Host IP address for LiDAR 1 packets"/>
  <arg name="lidar2_host_ip" default="192.168.2.100" description="Host IP address for LiDAR 2 packets"/>
  <arg name="lidar1_data_port" default="2368" description="UDP data port for LiDAR 1"/>
  <arg name="lidar2_data_port" default="2369" description="UDP data port for LiDAR 2"/>
  <arg name="lidar1_gnss_port" default="10110" description="GNSS port for LiDAR 1"/>
  <arg name="lidar2_gnss_port" default="10111" description="GNSS port for LiDAR 2"/>
  <arg name="imu_port" default="/dev/ttyUSB0" description="Tamagawa IMU serial port"/>
  <arg name="sensor_kit_description_file" default="$(find-pkg-share palta_sensor_kit_description)/urdf/standalone_sensors.xacro" description="path to standalone sensor kit xacro"/>
  <arg name="sensor_kit_config_dir" default="$(find-pkg-share palta_sensor_kit_description)/config" description="path to sensor kit calibration config dir"/>

  <group scoped="false">
    <include file="$(find-pkg-share autoware_vehicle_info_utils)/launch/vehicle_info.launch.py">
      <arg name="vehicle_info_param_file" value="$(var vehicle_info_param_file)"/>
    </include>
  </group>

  <group>
    <set_parameter name="use_sim_time" value="$(var use_sim_time)"/>

    <node name="robot_state_publisher" pkg="robot_state_publisher" exec="robot_state_publisher">
      <param name="robot_description" value="$(command 'xacro $(var sensor_kit_description_file) config_dir:=$(var sensor_kit_config_dir)' 'warn')"/>
    </node>

    <include file="$(find-pkg-share autoware_launch)/launch/pointcloud_container.launch.py">
      <arg name="use_multithread" value="true"/>
      <arg name="container_name" value="$(var pointcloud_container_name)"/>
    </include>

    <!-- LiDAR Driver -->
    <include file="$(find-pkg-share palta_sensor_kit_launch)/launch/lidar.launch.xml">
      <arg name="launch_driver" value="$(var launch_driver)"/>
      <arg name="lidar1_sensor_ip" value="$(var lidar1_sensor_ip)"/>
      <arg name="lidar2_sensor_ip" value="$(var lidar2_sensor_ip)"/>
      <arg name="lidar1_host_ip" value="$(var lidar1_host_ip)"/>
      <arg name="lidar2_host_ip" value="$(var lidar2_host_ip)"/>
      <arg name="lidar1_data_port" value="$(var lidar1_data_port)"/>
      <arg name="lidar2_data_port" value="$(var lidar2_data_port)"/>
      <arg name="lidar1_gnss_port" value="$(var lidar1_gnss_port)"/>
      <arg name="lidar2_gnss_port" value="$(var lidar2_gnss_port)"/>
      <arg name="vehicle_mirror_param_file" value="$(var vehicle_mirror_param_file)"/>
      <arg name="pointcloud_container_name" value="$(var pointcloud_container_name)"/>
    </include>

    <!-- IMU Driver -->
    <include file="$(find-pkg-share palta_sensor_kit_launch)/launch/imu.launch.xml">
      <arg name="launch_driver" value="$(var launch_driver)"/>
      <arg name="imu_port" value="$(var imu_port)"/>
    </include>

    <!-- Vehicle Velocity Converter  -->
    <include file="$(find-pkg-share autoware_vehicle_velocity_converter)/launch/vehicle_velocity_converter.launch.xml">
      <arg name="input_vehicle_velocity_topic" value="/vehicle/status/velocity_status"/>
      <arg name="output_twist_with_covariance" value="/sensing/vehicle_velocity_converter/twist_with_covariance"/>
    </include>
  </group>
</launch>
